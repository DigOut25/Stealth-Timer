{
  "expo": {
    "name": "Stealth Timer",
    "slug": "stealth-timer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "stealth-timer",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.stealthbjj.timer",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Stealth BJJ Timer uses the microphone to record custom sounds for round and rest end alerts. For example, you can record your coach's voice or a gym bell to use as your timer sound."
      }
    },
    "android": {
      "splash": {
        "backgroundColor": "#000000"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.stealthbjj.timer"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-asset", "expo-font", "expo-router", "./plugins/fix-splash-screen"],
    "extra": {
      "eas": {
        "projectId": "db99c69c-d367-485a-a756-9fb02a8f04c0"
      }
    },
    "owner": "nickb-57"
  }
}
